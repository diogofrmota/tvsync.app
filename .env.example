# TMDB is required at runtime for discovery/detail content (routes render dynamically).
TMDB_API_URL=https://api.themoviedb.org/3
TMDB_API_KEY=your_tmdb_api_key
# ISO 3166-1 country used for regional streaming availability (defaults to US).
TMDB_WATCH_REGION=US

# Use the pooled Neon connection string for serverless runtime access.
DATABASE_URL=postgres://user:password@host/database?sslmode=require

# Use the unpooled/direct Neon connection string only for migrations or psql.
DATABASE_URL_UNPOOLED=postgres://user:password@host/database?sslmode=require

# Auth.js / NextAuth Google OAuth.
AUTH_SECRET=generate_a_strong_auth_secret
# Use https://tvsync.app for both URL values in the production environment.
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend delivery for verification and password-reset emails.
RESEND_API_KEY=
# Use a verified sender in production, for example: TvSync <auth@tvsync.app>
AUTH_EMAIL_FROM=
# Optional reply-to address for authentication email support.
AUTH_EMAIL_REPLY_TO=

# Resend delivery for the public Contact form. Required for Contact to send mail.
# Destination inbox that receives Contact form submissions.
CONTACT_EMAIL_TO=
# Optional sender override for Contact mail; falls back to AUTH_EMAIL_FROM.
CONTACT_EMAIL_FROM=

# Canonical site URL used by sitemap generation (https://tvsync.app in production).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional Umami analytics. Events are sent only when both are configured.
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_SRC=
